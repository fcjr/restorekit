# Copy to `.env` and fill in your values, then run `npm run build:signed`.
# `.env` is gitignored — never commit real values.

# SHA-1 of your "Developer ID Application" cert (from `security find-identity -v
# -p codesigning`). A hash — not the name — disambiguates duplicate certs.
APPLE_SIGNING_IDENTITY=

# Notarization via an App Store Connect API key
# (App Store Connect → Users and Access → Integrations → keys).
# APPLE_API_KEY_PATH may be absolute, or relative to apps/desktop (e.g. the
# default below points at a .p8 you drop next to this file — it's gitignored).
APPLE_API_ISSUER=
APPLE_API_KEY=
APPLE_API_KEY_PATH=acskey.p8

# Only used by CI (importing the .p12). Leave empty for local builds — your cert
# is read straight from your keychain.
APPLE_CERTIFICATE_PASSWORD=

# Auto-updater artifact signing (optional locally — CI publishes the update feed).
# Set the password for your Tauri minisign key to also produce signed updater
# artifacts; the key defaults to ~/.tauri/restorekit.key. Leave unset to build a
# signed + notarized app/dmg without updater artifacts.
# TAURI_SIGNING_PRIVATE_KEY=/path/to/restorekit.key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
